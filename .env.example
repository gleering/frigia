# Base
NEXT_PUBLIC_BASE_URL=https://frigiaperfumeria.com

# Database (PostgreSQL — recomendado: Neon free tier)
DATABASE_URL=postgresql://user:password@host/frigia_db?sslmode=require

# Admin
ADMIN_SECRET=una-clave-secreta-larga-y-segura

# Anthropic (para enriquecimiento de productos con IA)
ANTHROPIC_API_KEY=sk-ant-...

# Cloudinary (imágenes de productos)
CLOUDINARY_CLOUD_NAME=tu-cloud
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu-cloud

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-...

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=5492364000000

# Resend (emails transaccionales)
RESEND_API_KEY=re_...

# Sentry (opcional — monitoreo de errores)
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
